{
  "name": "@helsenorge/core-utils",
  "version": "38.0.0-beta.7",
  "description": "Samling av ulike verktøy og hjelpefunksjoner for bruk på Helsenorge",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/helsenorge/core-frontend-packages.git"
  },
  "files": [
    "lib"
  ],
  "exports": {
    "./blob": "./lib/blob.js",
    "./constants/languages": "./lib/constants/languages.js",
    "./date-fns-utils": "./lib/date-fns-utils.js",
    "./html-entities": "./lib/html-entities.js",
    "./object-utils": "./lib/object-utils.js",
    "./package.json": "./package.json",
    "./string-utils": "./lib/string-utils.js",
    "./types/entities": "./lib/types/entities.js",
    "./url": "./lib/url.js",
    "./useDebounce": "./lib/useDebounce.js",
    "./useKeepPreviousData": "./lib/useKeepPreviousData.js",
    "./useQuery": "./lib/useQuery.js",
    "./user-agents-utils": "./lib/user-agents-utils.js",
    "./validation-utils": "./lib/validation-utils.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf lib",
    "prebuild": "npm run clean",
    "build": "tsc",
    "postbuild": "npm-run-all copy exports",
    "copy": "library-scripts copy --rm=lib/**/__*__ --rm=lib/**/*.stories.*",
    "exports": "library-scripts exports",
    "watch": "tsc --watch",
    "test": "cross-env TZ=Europe/Oslo vitest",
    "eslint": "eslint src/**/*.{js,jsx,ts,tsx}",
    "eslint:fix": "npm run eslint -- --fix",
    "prettier": "prettier --check \"src/**/*.{ts,tsx,js,jsx,css,scss,md,json}\"",
    "prettier:fix": "npm run prettier -- --write",
    "pretypecheck": "tsc -v",
    "typecheck": "tsc --noEmit"
  },
  "author": "Norsk helsenett SF",
  "maintainers": [
    "ROX"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "devDependencies": {
    "@helsenorge/library-build": "^38.0.0-beta.7"
  },
  "dependencies": {
    "date-fns": "^4.1.0"
  }
}
