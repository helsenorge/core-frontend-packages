{
  "name": "@helsenorge/library-build",
  "version": "37.8.1",
  "publishConfig": {
    "access": "public"
  },
  "author": "Norsk helsenett SF",
  "maintainers": [
    "ROX"
  ],
  "description": "Bygg og test av komponentbibliotek",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/helsenorge/core-frontend-packages.git"
  },
  "bin": {
    "library-scripts": "./lib/library-scripts.js"
  },
  "files": [
    "config",
    "lib"
  ],
  "exports": {
    "./config/tsconfig.global.json": "./config/tsconfig.global.json",
    "./config/tsconfig.node.json": "./config/tsconfig.node.json",
    "./config/tsconfig.vite.json": "./config/tsconfig.vite.json",
    "./copy": "./lib/copy.js",
    "./exports": "./lib/exports.js",
    "./library-scripts": "./lib/library-scripts.js",
    "./package.json": "./package.json",
    "./setupTests.vite": "./lib/setupTests.vite.js",
    "./vite.config": "./lib/vite.config.js",
    "./vitest.config": "./lib/vitest.config.js"
  },
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf lib",
    "prebuild": "npm run clean",
    "build": "tsc",
    "postbuild": "npm-run-all chmod exports",
    "chmod": "chmod +x lib/library-scripts.js",
    "exports": "./lib/library-scripts.js exports",
    "watch": "tsc --watch",
    "eslint": "eslint src/**/*.{js,jsx,ts,tsx}",
    "eslint:fix": "npm run eslint -- --fix",
    "prettier": "prettier --check \"src/**/*.{ts,tsx,js,jsx,css,scss,md,json}\"",
    "prettier:fix": "npm run prettier -- --write",
    "pretypecheck": "tsc -v",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/yargs": "^17.0.35",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "dependencies": {
    "@helsenorge/eslint-config": "^37.8.1",
    "@helsenorge/typed-scss-modules": "^9.0.9",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/copyfiles": "^2.4.4",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.17",
    "copyfiles": "^2.4.1",
    "jsdom": "^26.1.0",
    "node-fetch": "^3.3.2",
    "rimraf": "^6.1.2",
    "sass": "^1.94.2",
    "sass-embedded": "^1.93.3",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.6",
    "yargs": "^18.0.0"
  },
  "engineStrict": true,
  "engines": {
    "node": "^22.0.0 || ^24.0.0",
    "npm": ">=10.0.0"
  }
}
