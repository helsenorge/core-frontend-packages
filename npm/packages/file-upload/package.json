{
  "name": "@helsenorge/file-upload",
  "version": "38.0.0-beta.11",
  "publishConfig": {
    "access": "public"
  },
  "author": "Norsk helsenett SF",
  "maintainers": [
    "ROX"
  ],
  "license": "MIT",
  "description": "Komponent for opplasting av filer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/helsenorge/core-frontend-packages.git"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "lib"
  ],
  "scripts": {
    "prestart": "rimraf dist",
    "start": "vite dev --port 3000 --open",
    "clean": "rimraf lib",
    "typed-scss-modules": "typed-scss-modules \"src/**/*.module.scss\" --nameFormat none --exportType default --includePaths node_modules ../../../node_modules",
    "prebuild": "npm run clean",
    "build": "tsc",
    "postbuild": "npm-run-all copy exports",
    "copy": "library-scripts copy --include=src/**/*.{scss,scss.d.ts} --rm=lib/**/__*__ --rm=lib/**/*.stories.*",
    "exports": "library-scripts exports",
    "watch": "tsc --watch",
    "eslint": "eslint src/**/*.{js,jsx,ts,tsx}",
    "eslint:fix": "npm run eslint -- --fix",
    "stylelint": "stylelint src/**/*.{css,scss}",
    "stylelint:fix": "npm run stylelint -- --fix",
    "prettier": "prettier --check \"src/**/*.{ts,tsx,js,jsx,css,scss,md,json}\"",
    "prettier:fix": "npm run prettier -- --write",
    "pretypecheck": "tsc -v",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "peerDependencies": {
    "@helsenorge/core-utils": "^38.0.0-beta",
    "@helsenorge/designsystem-react": "^13.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "optionalDependencies": {
    "react-hook-form": "^7.71.1"
  },
  "devDependencies": {
    "@helsenorge/core-utils": "^38.0.0-beta.11",
    "@helsenorge/designsystem-react": "^13.5.0",
    "@helsenorge/library-build": "^38.0.0-beta.11",
    "@storybook/react-vite": "^10.2.5",
    "npm-run-all2": "^8.0.4",
    "react-hook-form": "^7.71.1"
  },
  "exports": {
    "./components/file-upload": "./lib/components/file-upload/index.js",
    "./components/file-upload/file": "./lib/components/file-upload/file.js",
    "./components/file-upload/useFileUpload": "./lib/components/file-upload/useFileUpload.js",
    "./components/file-upload/validate-utils": "./lib/components/file-upload/validate-utils.js",
    "./package.json": "./package.json",
    "./resources": "./lib/resources/index.js"
  }
}
